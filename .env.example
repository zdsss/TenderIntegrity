# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/tender_integrity.db

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# File Storage
UPLOAD_DIR=./data/uploads
REPORT_DIR=./data/reports

# LLM Settings
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Risk Thresholds (override thresholds.yaml)
# HIGH_RISK_THRESHOLD=85
# MEDIUM_RISK_THRESHOLD=65
# LOW_RISK_THRESHOLD=45
